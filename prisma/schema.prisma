// Setup Link :  https://www.prisma.io/docs/prisma-orm/quickstart/postgresql

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

model Movie{
    id Int @id @default(autoincrement())
    title String
    synopsis String?
    runtime Int?
    release_date DateTime?
    release_type String?
    classification String?
    collection_name String?
    age_rating String
    trailer_url String?
    banner_url String
    poster_url String
    ott_url String?
    ott_platform String?
    country String
    created_at DateTime @default(now())
    genres Genre[]
    language Language[]
    moviecast MovieCast[]
    collections Collection[]
    watchlists Watchlist[]
    articles Article[]
    ratings Ratings[]
    
}

model Genre{
  id Int @id @default(autoincrement())
  genre_name  Genre_Name @unique
  movies Movie[]
}
model Language{
  id Int @id @default(autoincrement())
  name Language_Name @unique
  is_original Boolean @default(false)
  movies Movie[]
}
model People{
  id Int @id @default(autoincrement())
  name String 
  professions Profession[]
  biography String?
  profile_url String?
  banner_url String?
  cast MovieCast[] // to get charcater name too
}
model MovieCast{
  id Int @id @default(autoincrement())
  character_name String?
  role Profession?
  
  movie Movie @relation(fields: [movie_id], references: [id])
  movie_id  Int
  person    People @relation(fields: [person_id], references: [id])
  person_id Int
  
}
model Collection{
  id Int @id @default(autoincrement())
  title String
  movies Movie[]
  cover_url String
  banner_url String
  description String?
  created_at DateTime @default(now())
}
model User{
  id Int @id @default(autoincrement())
  username String? @unique
  email String @unique
  name String
  image String?
  google_id String @unique
  role Role @default(GUEST)
  password String?
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  watchlists Watchlist?
  comments Comments[]
  articles Article[]
  ratings Ratings[]

}

model Watchlist {
  collection_id Int @id @default(autoincrement())
  created_at    DateTime       @default(now())

  user    User   @relation(fields: [user_id], references: [id])
  user_id Int    @unique
  movies Movie[]
}
model Article{
  article_id Int @id @default(autoincrement())
  author_id Int
  user User   @relation(fields: [author_id], references: [id])
  movie_id Int?
  movie Movie? @relation(fields: [movie_id],references: [id])

  cover_url String
  status Approval @default(PROCESSING)
  content String
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  published_at DateTime?
  comments Comments[]
}
model Comments{
  comment_id Int @id @default(autoincrement())
  user_id Int
  user User @relation(fields: [user_id], references: [id])
  comment_text String
  created_at DateTime @default(now())
  article_id Int
  article Article @relation(fields: [article_id],references: [article_id])
  
}

model Ratings{
  rating_id Int @id @default(autoincrement())
  movie_id Int

  movie Movie @relation(fields: [movie_id],references: [id])
  created_at DateTime @default(now())
  user  User @relation(fields: [user_id], references: [id])
  user_id    Int
  
  rating RatingType 
  @@unique([user_id, movie_id])
}

